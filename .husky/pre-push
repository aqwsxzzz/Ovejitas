npm run build

# Version sync check
PKG_VERSION=$(node -p "require('./package.json').version")
LATEST_TAG=$(git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//')

bump_version() {
  exec < /dev/tty
  echo ""
  printf "   Choose bump type [patch/minor/major/skip]: "
  read -r BUMP
  case "$BUMP" in
    patch|minor|major)
      npm version "$BUMP" --no-git-tag-version
      NEW_VERSION=$(node -p "require('./package.json').version")
      git add package.json package-lock.json 2>/dev/null
      git commit -m "chore(release): v$NEW_VERSION"
      git tag -a "v$NEW_VERSION" -m "v$NEW_VERSION"
      echo "   ✔ Bumped to v$NEW_VERSION and created tag."
      ;;
    skip)
      echo "   Proceeding without version bump."
      ;;
    *)
      echo "   Invalid option. Proceeding without version bump."
      ;;
  esac
}

if [ -z "$LATEST_TAG" ]; then
  echo ""
  echo "⚠️  No git tags found. package.json version is $PKG_VERSION."
  echo "   Would you like to create the first release tag now?"
  bump_version
elif [ "$PKG_VERSION" != "$LATEST_TAG" ]; then
  echo ""
  echo "⚠️  Version mismatch detected:"
  echo "   package.json : $PKG_VERSION"
  echo "   Latest tag   : $LATEST_TAG"
  echo "   Would you like to bump the version and create a tag now?"
  bump_version
fi
